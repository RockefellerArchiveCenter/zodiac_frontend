version: 0.0
os: linux
files:
  - source: ./
    destination: ${ROOT_DIR}
hooks:
  AfterInstall:
    - location: deploy_scripts/set_permissions.sh 
      timeout: 30
    - location: deploy_scripts/yarn_install.sh
      timeout: 300
    - location: deploy_scripts/yarn_start.sh
      timeout: 300
  ApplicationStart:
    - location: deploy_scripts/restart_httpd.sh
      timeout: 20
  ValidateService:
    - location: deploy_scripts/curl_index.sh
      timeout: 10
