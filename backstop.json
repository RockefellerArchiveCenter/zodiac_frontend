{
  "id": "backstop_default",
  "viewports": [
    {
      "label": "phone",
      "width": 320,
      "height": 480
    },
    {
      "label": "tablet",
      "width": 1024,
      "height": 768
    },
    {
      "label": "desktop",
      "width": 1920,
      "height": 1080
    }
  ],
  "onBeforeScript": "puppet/onBefore.js",
  "onReadyScript": "puppet/onReady.js",
  "scenarios": [
    {
      "label": "Homepage",
      "url": "http://host.docker.internal:3000/",
      "delay": 3000
    },
    {
      "label": "404 Page",
      "url": "http://host.docker.internal:3000/404"
    },
    {
      "label": "Package Errors",
      "url": "http://host.docker.internal:3000/errors"
    },
    {
      "label": "Package Details",
      "url": "http://host.docker.internal:3000/packages/f78742e5-6af9-4756-a94a-6cd297406d51"
    },
    {
      "label": "Event Details",
      "url": "http://host.docker.internal:3000/events/f78742e5-6af9-4756-a94a-6cd297406d55"
    },
    {
      "label": "Rerun Service Modal",
      "url": "http://host.docker.internal:3000/events/f78742e5-6af9-4756-a94a-6cd297406d55",
      "clickSelector": ".btn"
    },
    {
      "label": "Event Page Alert",
      "url": "http://host.docker.internal:3000/events/f78742e5-6af9-4756-a94a-6cd297406d55",
      "clickSelectors": [
        ".btn",
        ".btn--blue"
      ],
      "delay": 5000
    }
  ],
  "paths": {
    "bitmaps_reference": "backstop_data/bitmaps_reference",
    "bitmaps_test": "backstop_data/bitmaps_test",
    "engine_scripts": "backstop_data/engine_scripts",
    "html_report": "backstop_data/html_report",
    "ci_report": "backstop_data/ci_report"
  },
  "report": ["browser"],
  "engine": "puppeteer",
  "engineOptions": {
    "args": ["--no-sandbox"]
  },
  "asyncCaptureLimit": 1,
  "asyncCompareLimit": 50,
  "debug": false,
  "debugWindow": false
}
