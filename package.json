{
  "name": "zodiac_frontend",
  "version": "1.0.0",
  "description": "Track ingest of packages and fix errors for born digital and digitized content.",
  "repository": "https://github.com/RockefellerArchiveCenter/zodiac_frontend.git",
  "author": "Rockefeller Archive Center",
  "license": "MIT",
  "dependencies": {
    "datatables.net-dt": "^2.2.2",
    "datatables.net-searchpanes-dt": "^2.3.3",
    "datatables.net-vue3": "^3.0.4",
    "dotenv-webpack": "^8.1.0",
    "vue": "^3.5.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "process": "^0.11.10",
    "vue-loader": "^17.3.1",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "vue"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest",
      "^.+\\.vue$": "@vue/vue3-jest"
    },
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "node",
        "node-addons"
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/components/$1"
    }
  },
  "scripts": {
    "build": "yarn run webpack --watch",
    "test": "jest"
  }
}
